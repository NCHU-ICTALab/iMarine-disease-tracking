# 疫情自動追溯 — 環境設定範本（複製為 .env）

# --- 資料庫 ---
DATABASE_URL=sqlite:///./data/epidemic_trace.db

# --- 追蹤範圍 ---
TARGET_PORT_UNLOCODE=TWKHH        # 高雄港
TRACK_LOOKBACK_DAYS=28            # 靠港序列回溯天數（涵蓋 14 天潛伏 + 緩衝）

# --- 疫情資料來源 ---
CDC_TRAVEL_ALERT_CSV=https://www.cdc.gov.tw/CountryEpidLevel/ExportCSV?type=0&fileName=TCDCTravelAlertAll.csv
WHO_DON_API=https://www.who.int/api/news/diseaseoutbreaknews

# --- AIS 來源（mock | aisstream）---
AIS_PROVIDER=aisstream            # mock=讀 data/mock_ais.json；aisstream=即時串流
AIS_MOCK_FILE=./data/mock_ais.json
AISSTREAM_API_KEY=                 # aisstream.io 申請的金鑰
# aisstream 即時收集參數（皆有預設，通常不用改）
AIS_COLLECT_SECONDS=45            # 每次連線收集秒數
AIS_PORT_RADIUS_KM=25            # 距港口座標多近視為「在港」
AIS_PORT_MAX_SOG=3               # SOG 高於此值視為過境、非靠港（節）

# --- 風險 / 推播 ---
NOTIFY_MIN_LEVEL=high             # 達此等級以上自動推播（low|medium|high|critical）
